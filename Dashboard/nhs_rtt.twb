      <column caption='% Over 52 Weeks' datatype='real' name='[% Over 18 Weeks (copy)_0801871423643649]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(&#10;SUM(&#10;IF [weeks_waiting] &gt; 52 THEN [patient_count] ELSE 0 END&#10;) / SUM([patient_count]) * 100&#10;, 2)' />
      </column>
      <column caption='Num Over 52 Weeks ' datatype='integer' name='[% Over 52 Weeks (copy)_0801871425798147]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [weeks_waiting] &gt; 52 THEN [patient_count] ELSE 0 END)' />
      </column>
      <column caption='% Over 18 Weeks' datatype='real' name='[Calculation_0801871421431808]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(&#10;SUM(&#10;IF [weeks_waiting] &gt; 18 THEN [patient_count] ELSE 0 END&#10;) / SUM([patient_count]) * 100&#10;, 2)' />
      </column>
      <column caption='Average Wait Time' datatype='real' name='[Calculation_0801871424716802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(SUM([weeks_waiting] * [patient_count]) / SUM([patient_count]), 2)' />
      </column>
      <column caption='Wait Time Target Classification' datatype='string' name='[Calculation_0801871429255172]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([weeks_waiting] * [patient_count]) / SUM([patient_count]) &lt; 18 THEN &apos;Within Target (&lt; 18 Weeks)&apos; &#10;ELSEIF SUM([weeks_waiting] * [patient_count]) / SUM([patient_count]) &lt; 52 THEN &apos;Moderate Delay (52+ Weeks)&apos; &#10;ELSE &apos;Long Wait (&gt; 52 Weeks)&apos; &#10;END' />
      </column>
